# ===== LAVERVOTREVEHICULE.FR — Environment variables =====
# Copy this file to .env.local and fill in the values.

# --- Application ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Database (Supabase / Neon / Postgres) ---
DATABASE_URL=

# --- Auth (NextAuth / Clerk) ---
AUTH_SECRET=
AUTH_URL=

# --- Stripe (payments) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Email (Resend / SendGrid) ---
RESEND_API_KEY=
EMAIL_FROM=contact@lavervotrevehicule.fr

# --- Google Maps (geocoding / distance) ---
GOOGLE_MAPS_API_KEY=

# --- Analytics (optional) ---
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
